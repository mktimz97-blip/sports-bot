{
  "name": "ruflo-v3",
  "version": "3.5.0",
  "description": "RuFlo V3.5 AI Ecosystem - DDD Architecture with Multi-Agent Swarm",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "eslint src/",
